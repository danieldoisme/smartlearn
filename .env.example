# Database Configuration
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# SQLAlchemy Connection String (leave blank to auto-build from DB_* with URL-encoded password)
DATABASE_URL=

# AI Model Server Configuration
AI_SERVER_URL=
AI_API_KEY=
AI_PARSER_MODEL=qwen
AI_PARSER_TIMEOUT_SECONDS=90
AI_PARSER_MAX_CHARS=48000
AI_PARSER_MAX_INPUT_TOKENS=8500
AI_PARSER_MAX_TOKENS=4000
AI_PARSER_MIN_CONFIDENCE=0.45

# AQG provider configuration (defaults to AI parser model if blank)
AQG_MODEL=qwen
AQG_TIMEOUT_SECONDS=120
AQG_MAX_TOKENS=4000
AQG_MAX_PASSAGES=18

# Auth / JWT
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8080

# Public URL of the frontend
FRONTEND_BASE_URL=http://localhost:5173

# Transactional email via SMTP. Leave SMTP_HOST empty to disable sending
# and log the email payload to the backend stdout instead.
# Resend SMTP example: smtp.resend.com:465, user=resend, password=<api_key>.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SmartLearn <onboarding@resend.dev>
SMTP_USE_SSL=true
RESET_TOKEN_TTL_MINUTES=30
